{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SemanticSufficiencyAudit",
  "type": "object",
  "additionalProperties": false,
  "required": ["audit_id", "episode_id", "brief_checksum", "research_checksum", "evidence_report_checksum", "thesis_checksum", "audited_by", "audit_method", "findings", "decision", "created_at"],
  "properties": {
    "audit_id": {"type": "string", "minLength": 1},
    "episode_id": {"type": "string", "minLength": 1},
    "brief_checksum": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "research_checksum": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "evidence_report_checksum": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "thesis_checksum": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "audited_by": {"type": "string", "minLength": 1},
    "audit_method": {"type": "string", "enum": ["AI_SEMANTIC_REVIEW"]},
    "findings": {"type": "array", "minItems": 1, "items": {"$ref": "#/definitions/finding"}},
    "decision": {"type": "string", "enum": ["PASS", "WARN", "FAIL", "BLOCKED"]},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "definitions": {
    "finding": {"type": "object", "additionalProperties": false, "required": ["criterion", "assessment", "rationale"], "properties": {"criterion": {"type": "string", "enum": ["CENTRAL_QUESTION", "INITIAL_HYPOTHESIS", "FINDING_RELEVANCE", "DEPTH_ADEQUACY", "RIVAL_PERSPECTIVE", "NARRATIVE_UTILITY", "EVIDENCE_DISTINCTION", "CRITICAL_CLAIMS", "THESIS_SUBSTANCE", "B5_I2_READINESS"]}, "assessment": {"type": "string", "enum": ["SATISFIED", "LIMITED", "NOT_SATISFIED"]}, "rationale": {"type": "string", "minLength": 1}}}
  }
}
