{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/voice_sample.json",
  "title": "VoiceSample",
  "type": "object",
  "additionalProperties": false,
  "required": ["sample_id", "locator", "checksum", "authorship", "text_type", "classification", "usage_authorization", "representativeness", "recorded_at", "lineage"],
  "properties": {
    "sample_id": {"type": "string", "minLength": 1},
    "locator": {"type": "string", "minLength": 1},
    "checksum": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
    "authorship": {"type": "string", "minLength": 1},
    "text_type": {"type": "string", "minLength": 1},
    "classification": {"type": "string", "enum": ["AUTHENTIC", "COMPLEMENTARY", "EXCLUDED"]},
    "usage_authorization": {"type": "string", "enum": ["AUTHORIZED", "NOT_AUTHORIZED"]},
    "representativeness": {"type": "string", "enum": ["HIGH", "MEDIUM", "LOW", "NOT_EVALUATED"]},
    "recorded_at": {"type": "string", "format": "date-time"},
    "lineage": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "inclusion_reason": {"type": "string", "minLength": 1},
    "exclusion_reason": {"type": "string", "minLength": 1}
  },
  "allOf": [
    {
      "if": {"properties": {"classification": {"enum": ["AUTHENTIC", "COMPLEMENTARY"]}}},
      "then": {"required": ["inclusion_reason"]}
    },
    {
      "if": {"properties": {"classification": {"const": "EXCLUDED"}}},
      "then": {"required": ["exclusion_reason"]}
    }
  ]
}
