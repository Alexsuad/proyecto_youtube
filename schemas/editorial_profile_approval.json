{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/editorial_profile_approval.json",
  "title": "EditorialProfileApproval",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "profile_version",
    "profile_checksum",
    "decision",
    "functional_owner_role",
    "voice_evidence_level",
    "evidence_summary",
    "limitations"
  ],
  "properties": {
    "profile_id": {"type": "string", "minLength": 1},
    "profile_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "profile_checksum": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
    "decision": {"type": "string", "enum": ["PENDING", "APPROVE", "REQUEST_CHANGES", "REJECT"]},
    "functional_owner_role": {"type": "string", "const": "TEAM_01"},
    "approved_by": {"type": "string", "minLength": 3, "pattern": "^(?!.*(?:PENDING|PLACEHOLDER|TBD|TODO|UNKNOWN)).+$"},
    "approved_at": {"type": "string", "format": "date-time"},
    "voice_evidence_level": {"type": "string", "const": "SPECIFICATION_BASED"},
    "evidence_summary": {"type": "string", "minLength": 1},
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "notes": {"type": "string"},
    "conditions": {"type": "array", "items": {"type": "string"}}
  },
  "allOf": [
    {
      "if": {"properties": {"decision": {"const": "PENDING"}}, "required": ["decision"]},
      "then": {"not": {"anyOf": [{"required": ["approved_by"]}, {"required": ["approved_at"]}]}}
    },
    {
      "if": {"properties": {"decision": {"enum": ["APPROVE", "REQUEST_CHANGES", "REJECT"]}}, "required": ["decision"]},
      "then": {"required": ["approved_by", "approved_at"]}
    }
  ]
}
