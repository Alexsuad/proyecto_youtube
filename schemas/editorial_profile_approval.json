{
  "$schema": "http://json-schema.org/draft-07/schema#", "$id": "https://masalladelguion.com/schemas/editorial_profile_approval.json", "title": "EditorialProfileApproval", "type": "object", "additionalProperties": false,
  "required": ["profile_id", "profile_version", "profile_checksum", "decision", "functional_owner_role", "approved_by", "approved_at"],
  "properties": {"profile_id": {"type": "string", "minLength": 1}, "profile_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}, "profile_checksum": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"}, "decision": {"type": "string", "enum": ["APPROVE", "REQUEST_CHANGES", "REJECT"]}, "functional_owner_role": {"type": "string", "const": "TEAM_01"}, "approved_by": {"type": "string", "minLength": 1}, "approved_at": {"type": "string", "format": "date-time"}, "notes": {"type": "string"}, "conditions": {"type": "array", "items": {"type": "string"}}}
}
