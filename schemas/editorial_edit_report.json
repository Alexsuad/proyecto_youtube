{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/editorial_edit_report.json",
  "title": "EditorialEditReport",
  "type": "object",
  "required": [
    "input_version",
    "output_version",
    "edit_type",
    "changes_by_category"
  ],
  "properties": {
    "input_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "output_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "edit_type": {
      "type": "string"
    },
    "changes_by_category": {
      "type": "object"
    },
    "continuity_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "redundancy_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "line_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "orality_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unresolved_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "invalidated_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
