{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/human_publication_approval.json",
  "title": "HumanPublicationApproval",
  "type": "object",
  "required": [
    "final_candidate_id",
    "audiovisual_version",
    "thumbnail_version",
    "title_version",
    "checksum",
    "decision",
    "approved_by",
    "approved_role",
    "approved_at",
    "has_final_audiovisual_assets"
  ],
  "properties": {
    "final_candidate_id": {
      "type": "string"
    },
    "audiovisual_version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "thumbnail_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "title_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "description_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "chapters_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "clips_and_music_manifest_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "synthetic_or_altered_content_review_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "final_rights_review_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "checksum": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64,
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "decision": {
      "type": "string",
      "enum": [
        "APPROVED_FOR_PUBLICATION",
        "REQUEST_CHANGES",
        "REJECT"
      ]
    },
    "approved_by": {
      "type": "string"
    },
    "approved_role": {
      "type": "string"
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "has_final_audiovisual_assets": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    },
    "invalidated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "invalidation_reason": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
