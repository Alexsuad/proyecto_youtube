{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/thesis_artifact.json",
  "title": "ThesisArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "thesis_id",
    "episode_id",
    "brief_version",
    "research_id",
    "evidence_report_id",
    "stage",
    "statement",
    "supporting_reasoning",
    "main_objection",
    "simplification_risk",
    "open_questions",
    "source_refs",
    "version",
    "created_at"
  ],
  "properties": {
    "thesis_id": {
      "type": "string",
      "minLength": 1
    },
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "brief_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "research_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_report_id": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "enum": [
        "THESIS_PROVISIONAL",
        "THESIS_REFINED"
      ]
    },
    "statement": {
      "type": "string",
      "minLength": 1
    },
    "supporting_reasoning": {
      "type": "string",
      "minLength": 1
    },
    "main_objection": {
      "type": "string",
      "minLength": 1
    },
    "nuance": {
      "type": "string"
    },
    "simplification_risk": {
      "type": "string",
      "minLength": 1
    },
    "open_questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "packaging_alignment": {
      "type": "string"
    },
    "viewer_transformation": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
