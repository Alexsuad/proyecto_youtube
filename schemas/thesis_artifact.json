{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/thesis_artifact.json",
  "title": "ThesisArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "thesis_id",
    "episode_id",
    "brief_version",
    "research_id",
    "evidence_report_id",
    "stage",
    "statement",
    "premises",
    "supporting_findings",
    "tensioning_evidence",
    "alternative_explanations",
    "assumptions",
    "revision_conditions",
    "inherited_constraints",
    "open_questions",
    "version",
    "created_at"
  ],
  "properties": {
    "thesis_id": {
      "type": "string",
      "minLength": 1
    },
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "brief_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "research_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_report_id": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "enum": [
        "THESIS_PROVISIONAL",
        "THESIS_REFINED"
      ]
    },
    "statement": {
      "type": "string",
      "minLength": 1
    },
    "premises": {"type": "array", "minItems": 1, "items": {"$ref": "#/definitions/premise"}},
    "supporting_findings": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "tensioning_evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/definitions/evidenceRelation"}},
    "alternative_explanations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "assumptions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "revision_conditions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "inherited_constraints": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "open_questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "packaging_alignment": {
      "type": "string"
    },
    "viewer_transformation": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "premise": {"type": "object", "additionalProperties": false, "required": ["premise_id", "statement", "finding_ids", "source_refs"], "properties": {"premise_id": {"type": "string", "minLength": 1}, "statement": {"type": "string", "minLength": 1}, "finding_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}, "source_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}}},
    "evidenceRelation": {"type": "object", "additionalProperties": false, "required": ["finding_id", "explanation"], "properties": {"finding_id": {"type": "string", "minLength": 1}, "explanation": {"type": "string", "minLength": 1}}}
  }
}
