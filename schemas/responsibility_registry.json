{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Responsibility Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_version", "operational_agents", "real_subagents", "responsibilities", "functional_families", "legacy_role_mapping"],
  "properties": {
    "registry_version": {"type": "string"},
    "operational_agents": {"const": 1},
    "real_subagents": {"const": 0},
    "responsibilities": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"$ref": "#/$defs/contract"}},
    "functional_families": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/contract"}},
    "legacy_role_mapping": {"type": "array", "minItems": 11, "maxItems": 11, "items": {"type": "object", "additionalProperties": false, "required": ["legacy_role", "responsibility_ids"], "properties": {"legacy_role": {"type": "string"}, "responsibility_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}}}}}
  },
  "$defs": {
    "contract": {
      "type": "object", "additionalProperties": false,
      "required": ["role_id", "contract_type", "functional_owner", "purpose", "when_used", "inputs", "outputs", "read_permissions", "write_permissions", "forbidden_actions", "veto_conditions", "evidence", "handoff", "prompt_version"],
      "properties": {
        "role_id": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
        "contract_type": {"enum": ["BASE_RESPONSIBILITY", "TRANSVERSAL_FUNCTIONAL_FAMILY"]},
        "functional_owner": {"enum": ["CHANNEL_INTELLIGENCE", "SCRIPT_PRODUCT", "YOUTUBE_ADAPTATION", "TECHNICAL_GOVERNANCE"]},
        "purpose": {"type": "string", "minLength": 1}, "when_used": {"type": "string", "minLength": 1},
        "inputs": {"type": "array", "items": {"type": "string"}}, "outputs": {"type": "array", "items": {"type": "string"}},
        "read_permissions": {"type": "array", "items": {"type": "string"}}, "write_permissions": {"type": "array", "items": {"type": "string"}},
        "forbidden_actions": {"type": "array", "items": {"type": "string"}}, "veto_conditions": {"type": "array", "items": {"type": "string"}},
        "evidence": {"type": "array", "items": {"type": "string"}}, "handoff": {"type": "array", "items": {"type": "string"}},
        "prompt_version": {"type": ["string", "null"]}
      }
    }
  }
}
