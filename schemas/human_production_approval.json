{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/human_production_approval.json",
  "title": "HumanProductionApproval",
  "type": "object",
  "required": [
    "publication_package_id",
    "publication_package_version",
    "script_version",
    "packaging_version",
    "checksum",
    "decision",
    "approved_by",
    "approved_role",
    "approved_at"
  ],
  "properties": {
    "publication_package_id": {
      "type": "string"
    },
    "publication_package_version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "script_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "packaging_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "platform_and_rights_review_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "checksum": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64,
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "decision": {
      "type": "string",
      "enum": [
        "APPROVED_FOR_PRODUCTION",
        "REQUEST_CHANGES",
        "REJECT"
      ]
    },
    "approved_by": {
      "type": "string"
    },
    "approved_role": {
      "type": "string"
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    },
    "invalidated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "invalidation_reason": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
