{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/source_access_and_evidence_report.json",
  "title": "SourceAccessAndEvidenceReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "episode_id",
    "research_id",
    "brief_version",
    "material_principal_disponible",
    "tipo_de_acceso",
    "fuentes_primarias",
    "fuentes_secundarias",
    "escenas_verificadas",
    "escenas_descritas_indirectamente",
    "claims_sostenibles",
    "claims_pendientes",
    "limitaciones",
    "nivel_de_confianza",
    "can_proceed",
    "allowed_analyses",
    "limited_analyses",
    "prohibited_analyses",
    "excluded_claims",
    "required_disclosures",
    "propagated_constraints",
    "critical_claim_assessments",
    "critical_claims_propagation",
    "sufficiency_basis",
    "created_at"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "research_id": {
      "type": "string",
      "minLength": 1
    },
    "brief_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "material_principal_disponible": {
      "type": "boolean"
    },
    "tipo_de_acceso": {
      "type": "string",
      "enum": [
        "DIRECT",
        "INDIRECT",
        "MIXED",
        "UNAVAILABLE"
      ]
    },
    "fuentes_primarias": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/sourceEntry"
      }
    },
    "fuentes_secundarias": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/sourceEntry"
      }
    },
    "escenas_verificadas": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/sceneEntry"
      }
    },
    "escenas_descritas_indirectamente": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/sceneEntry"
      }
    },
    "claims_sostenibles": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/claimEntry"
      }
    },
    "claims_pendientes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/pendingClaim"
      }
    },
    "limitaciones": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "nivel_de_confianza": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH"
      ]
    },
    "can_proceed": {
      "type": "boolean"
    },
    "allowed_analyses": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "limited_analyses": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "prohibited_analyses": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "excluded_claims": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "required_disclosures": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "propagated_constraints": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "critical_claim_assessments": {"type": "array", "items": {"$ref": "#/definitions/criticalClaimAssessment"}},
    "critical_claims_propagation": {"$ref": "#/definitions/criticalClaimsPropagation"},
    "sufficiency_basis": {"type": "object", "additionalProperties": false, "required": ["central_question", "critical_claims", "analysis_type", "material_roles", "requested_depth", "research_coverage"], "properties": {"central_question": {"type": "string", "minLength": 1}, "critical_claims": {"type": "array", "items": {"type": "string", "minLength": 1}}, "analysis_type": {"type": "string", "minLength": 1}, "material_roles": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "requested_depth": {"type": "string", "minLength": 1}, "research_coverage": {"type": "string", "minLength": 1}}},
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "criticalClaimAssessment": {
      "type": "object", "additionalProperties": false,
      "required": ["claim_id", "claim_text", "support_status", "confidence", "allowed_scope", "evidence_refs"],
      "properties": {
        "claim_id": {"type": "string", "minLength": 1},
        "claim_text": {"type": "string", "minLength": 1},
        "support_status": {"type": "string", "enum": ["SUPPORTED", "LIMITED", "EXCLUDED", "INSUFFICIENT"]},
        "confidence": {"type": "string", "enum": ["LOW", "MEDIUM", "HIGH"]},
        "allowed_scope": {"type": "string", "minLength": 1}
        ,"evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    },
    "criticalClaimsPropagation": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "claim_ids", "justification", "editorial_impact", "scope_decision"],
      "properties": {
        "status": {"type": "string", "enum": ["IDENTIFIED", "NONE_JUSTIFIED"]},
        "claim_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "justification": {"type": ["string", "null"]},
        "editorial_impact": {"type": "string", "enum": ["NONE", "LIMITED", "MATERIAL", "CRITICAL"]},
        "scope_decision": {"type": "string", "minLength": 1}
      }
    },
    "sourceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "title",
        "access_type",
        "locator",
        "confidence"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "access_type": {
          "type": "string",
          "enum": [
            "DIRECT",
            "INDIRECT",
            "SECONDARY_ONLY"
          ]
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH"
          ]
        }
      }
    },
    "sceneEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scene_id",
        "description",
        "source_id",
        "locator",
        "verification_mode"
      ],
      "properties": {
        "scene_id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "verification_mode": {
          "type": "string",
          "enum": [
            "DIRECT",
            "INDIRECT"
          ]
        }
      }
    },
    "claimEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "claim_text",
        "source_refs",
        "locator",
        "confidence"
      ],
      "properties": {
        "claim_id": {
          "type": "string",
          "minLength": 1
        },
        "claim_text": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH"
          ]
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "pendingClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "claim_text",
        "reason"
      ],
      "properties": {
        "claim_id": {
          "type": "string",
          "minLength": 1
        },
        "claim_text": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "attempted_source_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "locator": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH"
          ]
        }
      }
    }
  }
}
