{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/editorial_profile.json",
  "title": "EditorialProfile",
  "type": "object",
  "required": [
    "profile_id",
    "channel_id",
    "version",
    "status",
    "created_at",
    "updated_at",
    "functional_owner_role",
    "functional_approval_status",
    "functional_approved_by",
    "functional_approved_at",
    "identity",
    "purpose",
    "positioning",
    "primary_promise",
    "checksum"
  ],
  "properties": {
    "profile_id": {
      "type": "string"
    },
    "channel_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "IN_REVIEW",
        "EDITORIAL_SCRIPT_APPROVED",
        "YOUTUBE_PRODUCTION_READY",
        "YOUTUBE_READY",
        "PUBLISHED",
        "DEPRECATED",
        "INVALIDATED"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "functional_owner_role": {
      "type": "string"
    },
    "functional_approval_status": {
      "type": "string"
    },
    "functional_approved_by": {
      "type": "string"
    },
    "functional_approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "identity": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "positioning": {
      "type": "string"
    },
    "primary_promise": {
      "type": "string"
    },
    "secondary_benefits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "audience": {
      "type": "string"
    },
    "audience_relationship": {
      "type": "string"
    },
    "brand_personality": {
      "type": "string"
    },
    "narrator_role": {
      "type": "string"
    },
    "editorial_territories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pillars": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exclusions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tone": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "checksum": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64,
      "pattern": "^[0-9a-fA-F]{64}$"
    }
  }
}
