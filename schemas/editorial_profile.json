{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/editorial_profile.json",
  "title": "EditorialProfile",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile_id", "channel_id", "version", "status", "functional_owner_role", "source_lineage", "identity_stable", "audience_hypotheses", "voice_profile", "supported_delivery_formats", "external_policy_references", "pending_decisions"],
  "definitions": {
    "checksum": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "locator", "checksum", "role"],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "locator": {"type": "string", "minLength": 1},
        "checksum": {"$ref": "#/definitions/checksum"},
        "role": {"type": "string", "enum": ["FUNCTIONAL_SPECIFICATION", "MIGRATION_SOURCE", "VOICE_CORPUS_MANIFEST"]}
      }
    },
    "territory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "classification"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "classification": {"type": "string", "enum": ["ACTIVE", "EXPERIMENTAL", "EXCLUDED", "PENDING"]}
      }
    }
  },
  "properties": {
    "profile_id": {"type": "string", "minLength": 1},
    "channel_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "status": {"type": "string", "enum": ["DRAFT", "IN_REVIEW", "APPROVED", "DEPRECATED", "INVALIDATED"]},
    "functional_owner_role": {"type": "string", "const": "TEAM_01"},
    "source_lineage": {"type": "array", "minItems": 1, "items": {"$ref": "#/definitions/source"}},
    "identity_stable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "purpose", "positioning", "primary_promise", "differentiator", "editorial_pillars", "territories", "permanent_limits", "authorial_persona", "first_person_rule"],
      "properties": {
        "identity": {"type": "string", "minLength": 1},
        "purpose": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "positioning": {"type": "string", "minLength": 1},
        "primary_promise": {"type": "string", "minLength": 1},
        "differentiator": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "editorial_pillars": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "territories": {"type": "array", "minItems": 1, "items": {"$ref": "#/definitions/territory"}},
        "permanent_limits": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "authorial_persona": {"type": "object", "additionalProperties": false, "required": ["acts_as", "does_not_act_as", "voice_traits"], "properties": {"acts_as": {"type": "string", "minLength": 1}, "does_not_act_as": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "voice_traits": {"type": "array", "minItems": 1, "items": {"type": "string"}}}},
        "first_person_rule": {"type": "string", "const": "FIRST_PERSON_ALLOWED_WHEN_TRUE_AND_EDITORIALLY_RELEVANT"}
      }
    },
    "audience_hypotheses": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["classification", "statement", "status"], "properties": {"classification": {"type": "string", "const": "AUDIENCE_HYPOTHESIS_INITIAL"}, "statement": {"type": "string", "minLength": 1}, "status": {"type": "string", "const": "HYPOTHESIS"}}}},
    "voice_profile": {"type": "object", "additionalProperties": false, "required": ["corpus_status", "approved_sample_ids", "initial_authorized_patterns", "anti_imitation_rules", "approved_positive_examples", "approved_negative_examples"], "properties": {"corpus_status": {"type": "string", "enum": ["INCOMPLETE_MISSING_REQUIRED_SAMPLE", "READY", "SPECIFICATION_BASED", "AUTHENTIC_CORPUS_PARTIAL", "AUTHENTIC_CORPUS_VALIDATED"]}, "approved_sample_ids": {"type": "array", "items": {"type": "string"}}, "initial_authorized_patterns": {"type": "array", "items": {"type": "string"}}, "anti_imitation_rules": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "approved_positive_examples": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "approved_negative_examples": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}}, "allOf": [{"if": {"properties": {"corpus_status": {"const": "AUTHENTIC_CORPUS_VALIDATED"}}}, "then": {"properties": {"approved_sample_ids": {"minItems": 1}}}}]},
    "supported_delivery_formats": {"type": "array", "minItems": 3, "items": {"type": "string", "enum": ["VIDEO_ESSAY", "AUDIOVISUAL_NARRATION", "NARRATIVE_PODCAST", "REFLECTIVE_PODCAST", "AUDIO_CONTENT", "COMPATIBLE_DERIVATIVE"]}, "uniqueItems": true},
    "external_policy_references": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["policy_type", "policy_id", "version"], "properties": {"policy_type": {"type": "string", "enum": ["EDITORIAL_POLICY_VERSIONED", "PLATFORM_POLICY_VERSIONED", "FORMAT_PREFERENCE"]}, "policy_id": {"type": "string", "minLength": 1}, "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"}}}},
    "pending_decisions": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
