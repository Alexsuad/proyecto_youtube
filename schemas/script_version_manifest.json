{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/script_version_manifest.json",
  "title": "ScriptVersionManifest",
  "type": "object",
  "required": [
    "script_id",
    "version",
    "checksum",
    "narrative_plan_version",
    "status"
  ],
  "properties": {
    "script_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "checksum": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64,
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "narrative_plan_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "blocks_manifest": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "total_words": {
      "type": "integer"
    },
    "status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "IN_REVIEW",
        "EDITORIAL_SCRIPT_APPROVED",
        "YOUTUBE_PRODUCTION_READY",
        "YOUTUBE_READY",
        "PUBLISHED",
        "DEPRECATED",
        "INVALIDATED"
      ]
    }
  }
}
