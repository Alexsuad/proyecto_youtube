{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/gate_result.json",
  "title": "GateResult",
  "type": "object",
  "required": [
    "gate_id",
    "artifact_id",
    "artifact_version",
    "status",
    "summary",
    "violations",
    "warnings",
    "evidence",
    "checked_at",
    "checker_version",
    "exit_code"
  ],
  "properties": {
    "gate_id": {
      "type": "string"
    },
    "artifact_id": {
      "type": "string"
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "WARN",
        "FAIL",
        "BLOCKED"
      ]
    },
    "summary": {
      "type": "string"
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "object"
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "checker_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "exit_code": {
      "type": "integer",
      "enum": [
        0,
        1,
        2,
        3
      ]
    }
  },
  "additionalProperties": false
}
