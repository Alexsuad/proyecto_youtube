{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/editorial_learning_candidate.json",
  "title": "EditorialLearningCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["learning_id", "target_profile_id", "target_profile_version", "observed_change", "scope", "lineage", "evidence_items", "confidence", "examples", "counterexamples", "exceptions", "functional_decision", "status_history"],
  "definitions": {"checksum": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"}},
  "properties": {
    "learning_id": {"type": "string", "minLength": 1},
    "target_profile_id": {"type": "string", "minLength": 1},
    "target_profile_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "observed_change": {"type": "string", "minLength": 1},
    "scope": {"type": "string", "enum": ["VOICE", "IDENTITY", "EDITORIAL_POLICY", "FORMAT_PREFERENCE"]},
    "lineage": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "evidence_items": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["source_id", "locator", "checksum", "observation"], "properties": {"source_id": {"type": "string", "minLength": 1}, "locator": {"type": "string", "minLength": 1}, "checksum": {"$ref": "#/definitions/checksum"}, "observation": {"type": "string", "minLength": 1}}}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "examples": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "counterexamples": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "exceptions": {"type": "array", "items": {"type": "string"}},
    "functional_decision": {"type": "object", "additionalProperties": false, "required": ["status"], "properties": {"status": {"type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"]}, "decided_by": {"type": "string"}, "decided_at": {"type": "string", "format": "date-time"}, "notes": {"type": "string"}}},
    "status_history": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["status", "recorded_at"], "properties": {"status": {"type": "string", "enum": ["CANDIDATE", "APPROVED", "INTEGRATED", "REJECTED"]}, "recorded_at": {"type": "string", "format": "date-time"}, "reason": {"type": "string"}}}}
  }
}
