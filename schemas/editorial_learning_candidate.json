{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/editorial_learning_candidate.json",
  "title": "EditorialLearningCandidate",
  "type": "object",
  "required": [
    "learning_id",
    "observed_change",
    "reason",
    "scope",
    "status"
  ],
  "properties": {
    "learning_id": {
      "type": "string"
    },
    "observed_change": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "evidence_count": {
      "type": "integer"
    },
    "contexts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "CANDIDATE",
        "APPROVED",
        "INTEGRATED",
        "REJECTED"
      ]
    },
    "approved_by": {
      "type": "string"
    },
    "approved_role": {
      "type": "string"
    },
    "source_episode_versions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
