{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/episode_brief.json",
  "title": "EpisodeBrief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_id",
    "brief_version",
    "profile_id",
    "profile_version",
    "profile_checksum",
    "tema",
    "pregunta_central",
    "conflicto_o_tension",
    "initial_editorial_hypothesis",
    "objetivo",
    "transformacion_esperada",
    "audiencia_concreta",
    "audience_status",
    "angulo_diferencial",
    "alcance",
    "fuera_de_alcance",
    "spoilers",
    "tono",
    "duracion_objetivo",
    "ritmo_locucion",
    "nivel_investigacion",
    "narrative_materials",
    "tipo_de_guion_principal",
    "estructura_candidata",
    "structure_status",
    "razon_eleccion_estructura",
    "citation_style",
    "attribution_policy",
    "quotation_policy",
    "source_visibility",
    "salida_esperada",
    "created_at"
  ],
  "properties": {
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "brief_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "profile_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "profile_checksum": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "tema": {
      "type": "string",
      "minLength": 1
    },
    "pregunta_central": {
      "type": "string",
      "minLength": 1
    },
    "conflicto_o_tension": {
      "type": "string",
      "minLength": 1
    },
    "initial_editorial_hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "status", "research_role", "revisable", "adversarial_research_required"],
      "properties": {
        "statement": {"type": "string", "minLength": 1},
        "status": {"type": "string", "enum": ["HYPOTHESIS_UNAPPROVED"]},
        "research_role": {"type": "string", "enum": ["ORIENTS_RESEARCH_NOT_APPROVED_THESIS"]},
        "revisable": {"type": "boolean", "const": true},
        "adversarial_research_required": {"type": "boolean", "const": true}
      }
    },
    "objetivo": {
      "type": "string",
      "minLength": 1
    },
    "transformacion_esperada": {
      "type": "string",
      "minLength": 1
    },
    "audiencia_concreta": {
      "type": "string",
      "minLength": 1
    },
    "audience_status": {"type": "string", "enum": ["INITIAL_HYPOTHESIS"]},
    "angulo_diferencial": {
      "type": "string",
      "minLength": 1
    },
    "alcance": {
      "type": "string",
      "minLength": 1
    },
    "fuera_de_alcance": {
      "type": "string",
      "minLength": 1
    },
    "spoilers": {
      "type": "string",
      "enum": [
        "NO",
        "SI_LIMITADOS",
        "SI_COMPLETOS"
      ]
    },
    "tono": {
      "type": "string",
      "minLength": 1
    },
    "duracion_objetivo": {
      "type": "string",
      "minLength": 1
    },
    "ritmo_locucion": {
      "type": "string",
      "minLength": 1
    },
    "nivel_investigacion": {
      "type": "string",
      "enum": [
        "BASICO",
        "ESTANDAR",
        "PROFUNDO",
        "CRITICO"
      ]
    },
    "fuentes_requeridas": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "narrative_materials": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "tipo_de_guion_principal": {
      "type": "string",
      "minLength": 1
    },
    "tipo_de_guion_secundario": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "estructura_candidata": {
      "type": "string",
      "minLength": 1
    },
    "structure_status": {"type": "string", "enum": ["INITIAL_HYPOTHESIS_REVISABLE_AFTER_RESEARCH"]},
    "razon_eleccion_estructura": {
      "type": "string",
      "minLength": 1
    },
    "citation_style": {
      "type": "string",
      "minLength": 1
    },
    "attribution_policy": {
      "type": "string",
      "minLength": 1
    },
    "quotation_policy": {
      "type": "string",
      "minLength": 1
    },
    "source_visibility": {
      "type": "string",
      "enum": [
        "INTERNAL_ONLY",
        "PUBLIC_SUMMARY",
        "PUBLIC_DETAILED"
      ]
    },
    "salida_esperada": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
