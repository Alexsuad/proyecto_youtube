{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://masalladelguion.com/schemas/research_pack.json",
  "title": "ResearchPack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "research_id",
    "episode_id",
    "brief_version",
    "scope",
    "facts",
    "interpretations",
    "hypotheses",
    "contradictions",
    "alternative_views",
    "coverage",
    "critical_claims_assessment",
    "narrative_evidence",
    "external_reality_evidence",
    "source_registry",
    "claims_candidates",
    "unsupported_claims",
    "narrative_opportunities",
    "limitations",
    "created_at"
  ],
  "properties": {
    "research_id": {
      "type": "string",
      "minLength": 1
    },
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "brief_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "facts": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/researchItem"
      }
    },
    "interpretations": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/researchItem"
      }
    },
    "hypotheses": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/researchItem"
      }
    },
    "contradictions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/researchItem"
      }
    },
    "alternative_views": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/researchItem"
      }
    },
    "coverage": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/definitions/coverageEntry"}
    },
    "critical_claims_assessment": {"$ref": "#/definitions/criticalClaimsAssessment"},
    "narrative_evidence": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/narrativeEvidence"
      }
    },
    "external_reality_evidence": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/externalEvidence"
      }
    },
    "source_registry": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/sourceRef"
      }
    },
    "claims_candidates": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/researchItem"
      }
    },
    "unsupported_claims": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/unsupportedClaim"
      }
    },
    "narrative_opportunities": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/researchItem"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "coverageEntry": {
      "type": "object", "additionalProperties": false,
      "required": ["dimension_id", "status", "related_finding_ids", "related_source_ids", "limitation_or_pending", "scope_decision", "editorial_impact", "propagated_constraint", "mitigation_status"],
      "properties": {
        "dimension_id": {"type": "string", "enum": ["CENTRAL_QUESTION", "CONFLICT", "INITIAL_HYPOTHESIS", "HUMAN_SOCIAL_HISTORICAL_OR_CULTURAL_PHENOMENON", "PRIMARY_NARRATIVE_MATERIAL", "CRITICAL_CLAIMS", "ALTERNATIVE_PERSPECTIVES"]},
        "status": {"type": "string", "enum": ["COVERED", "PARTIALLY_COVERED", "PENDING", "NOT_VERIFIABLE"]},
        "related_finding_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "related_source_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "limitation_or_pending": {"type": ["string", "null"]}
        ,"scope_decision": {"type": "string", "enum": ["NONE", "REDUCED_SCOPE", "BLOCKED"]},
        "editorial_impact": {"type": "string", "enum": ["NOT_APPLICABLE", "NON_CRITICAL", "CRITICAL"]},
        "propagated_constraint": {"type": ["string", "null"]},
        "mitigation_status": {"type": "string", "enum": ["NOT_REQUIRED", "MITIGATED", "INSUFFICIENT"]}
      }
    },
    "criticalClaimsAssessment": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "claim_ids", "justification", "editorial_impact"],
      "properties": {
        "status": {"type": "string", "enum": ["IDENTIFIED", "NONE_JUSTIFIED"]},
        "claim_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "justification": {"type": ["string", "null"]},
        "editorial_impact": {"type": "string", "enum": ["NONE", "LIMITED", "MATERIAL", "CRITICAL"]}
      }
    },
    "narrativeEvidence": {
      "allOf": [
        {"$ref": "#/definitions/researchItem"},
        {"properties": {"evidence_kind": {"type": "string", "enum": ["SCENE", "SEQUENCE", "DIALOGUE", "PASSAGE", "CHAPTER", "DECISION", "NARRATIVE_EVENT", "FORMAL_ELEMENT"]}}, "required": ["evidence_kind"]}
      ]
    },
    "externalEvidence": {
      "allOf": [
        {"$ref": "#/definitions/researchItem"},
        {"properties": {"evidence_kind": {"type": "string", "enum": ["STUDY", "DOCUMENT", "DATA", "STATEMENT", "HISTORICAL_RECORD", "INSTITUTIONAL_SOURCE", "VERIFIABLE_EVENT", "EXPERT_ANALYSIS"]}}, "required": ["evidence_kind"]}
      ]
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "title",
        "source_type",
        "access_type",
        "locator",
        "confidence"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "access_type": {
          "type": "string",
          "enum": [
            "DIRECT",
            "INDIRECT",
            "SECONDARY_ONLY"
          ]
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH"
          ]
        },
        "notes": {
          "type": "string"
        },
        "evidence_kind": {
          "type": "string"
        }
      }
    },
    "researchItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "statement",
        "source_refs",
        "locator",
        "confidence"
      ],
      "properties": {
        "item_id": {
          "type": "string",
          "minLength": 1
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH"
          ]
        },
        "material_id": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "evidence_kind": {
          "type": "string"
        }
      }
    },
    "unsupportedClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "statement",
        "reason"
      ],
      "properties": {
        "claim_id": {
          "type": "string",
          "minLength": 1
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "attempted_source_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    }
  }
}
