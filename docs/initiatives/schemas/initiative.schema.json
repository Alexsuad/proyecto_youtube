{
  "$schema": "http://json-schema.org/draft-07/schema#", "title": "InitiativeRecord", "type": "object", "additionalProperties": false,
  "required": ["initiative_id", "title", "problem", "value", "alternatives", "maturity_status", "classification_status", "scope_recommendation", "recommendation", "decision_status", "execution_status", "implementation_authorized", "authorization", "mvp_evaluation", "plan_evaluation", "relationship", "current_scope_reference", "architecture"],
  "properties": {
    "initiative_id": {"type": "string", "pattern": "^INIT-[0-9]+$"}, "title": {"type": "string", "minLength": 1}, "problem": {"type": "string", "minLength": 1}, "value": {"type": "string", "minLength": 1}, "alternatives": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "maturity_status": {"type": "string", "enum": ["CAPTURED", "READY_FOR_TRIAGE", "ASSESSED", "READY_FOR_DECISION"]}, "classification_status": {"type": "string", "enum": ["NEEDS_MVP_BASELINE", "CLASSIFIED", "NEEDS_OWNER_CLARIFICATION"]}, "scope_recommendation": {"type": "string", "enum": ["MVP", "CURRENT_PLAN", "POST_MVP", "OUT_OF_SCOPE", "UNDECIDED", "PROMOTED_TO_CURRENT_SCOPE"]},
    "recommendation": {"type": "object", "additionalProperties": false, "required": ["status", "rationale"], "properties": {"status": {"type": "string", "enum": ["UNDECIDED", "RECOMMEND", "DO_NOT_RECOMMEND", "PRESERVE_EXTENSION_POINT"]}, "rationale": {"type": "string", "minLength": 1}}}, "decision_status": {"type": "string", "enum": ["UNDECIDED", "PROPOSED", "APPROVED", "REJECTED", "DEFERRED"]}, "execution_status": {"type": "string", "enum": ["NOT_AUTHORIZED", "AUTHORIZED", "PLANNED", "IN_PROGRESS", "IMPLEMENTED"]}, "implementation_authorized": {"type": "boolean", "default": false},
    "authorization": {"type": ["object", "null"], "additionalProperties": false, "properties": {"approved_by": {"type": "string", "minLength": 1}, "approved_at": {"type": "string", "format": "date-time"}, "rationale": {"type": "string", "minLength": 1}}}, "mvp_evaluation": {"type": "object", "additionalProperties": false, "required": ["status", "rationale"], "properties": {"status": {"type": "string", "enum": ["PENDING_OWNER_APPROVAL", "IN_SCOPE", "OUT_OF_SCOPE", "UNKNOWN"]}, "rationale": {"type": "string", "minLength": 1}}}, "plan_evaluation": {"type": "object", "additionalProperties": false, "required": ["status", "rationale"], "properties": {"status": {"type": "string", "enum": ["NOT_COVERED", "PARTIALLY_RELATED", "COVERED", "UNKNOWN"]}, "rationale": {"type": "string", "minLength": 1}}},
    "relationship": {"type": "object", "additionalProperties": false, "required": ["type", "related_initiative_id"], "properties": {"type": {"type": "string", "enum": ["NONE", "DUPLICATE_OF", "DEPENDS_ON", "RELATES_TO"]}, "related_initiative_id": {"type": ["string", "null"], "pattern": "^INIT-[0-9]+$"}}}, "current_scope_reference": {"type": ["string", "null"]}, "architecture": {"type": ["object", "null"]}
  },
  "allOf": [
    {"if": {"properties": {"implementation_authorized": {"const": true}}}, "then": {"properties": {"authorization": {"type": "object", "required": ["approved_by", "approved_at", "rationale"]}}}},
    {"if": {"properties": {"execution_status": {"enum": ["PLANNED", "IN_PROGRESS", "IMPLEMENTED"]}}}, "then": {"properties": {"implementation_authorized": {"const": true}}}},
    {"if": {"properties": {"decision_status": {"enum": ["DEFERRED", "REJECTED"]}}}, "then": {"properties": {"execution_status": {"const": "NOT_AUTHORIZED"}}}},
    {"if": {"properties": {"scope_recommendation": {"const": "PROMOTED_TO_CURRENT_SCOPE"}}}, "then": {"properties": {"current_scope_reference": {"type": "string", "minLength": 1}}}},
    {"if": {"properties": {"relationship": {"properties": {"type": {"const": "NONE"}}}}}, "then": {"properties": {"relationship": {"properties": {"related_initiative_id": {"type": "null"}}}}}},
    {"if": {"properties": {"relationship": {"properties": {"type": {"enum": ["DUPLICATE_OF", "DEPENDS_ON", "RELATES_TO"]}}}}}, "then": {"properties": {"relationship": {"properties": {"related_initiative_id": {"type": "string", "pattern": "^INIT-[0-9]+$"}}}}}}
  ]
}
